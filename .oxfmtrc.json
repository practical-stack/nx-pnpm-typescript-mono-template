{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    ".next",
    ".omc",
    "pnpm-lock.yaml",
    "*.md",
    "**/next-env.d.ts",
    "**/routeTree.gen.ts"
  ]
}
